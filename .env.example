# ─── REQUIRED ──────────────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Your deployed URL (no trailing slash). For local dev: http://localhost:3001
APP_URL=http://localhost:3001

# Random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_this_with_a_long_random_string

# ─── OPTIONAL ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Google Search Console site URL (enables SEO tab)
GSC_SITE_URL=https://wiser.io
